<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="OrangeHRM Cross Browser Suite"
       parallel="tests"
       thread-count="3">

    <!-- Chrome -->
    <test name="Chrome">

        <parameter name="browser" value="chromium"/>

        <classes>

            <class name="tests.LoginTest"/>

            <class name="tests.LogoutTest"/>

        </classes>

    </test>

    <!-- Firefox -->
    <test name="Firefox">

        <parameter name="browser" value="firefox"/>

        <classes>

            <class name="tests.LoginTest"/>

            <class name="tests.LogoutTest"/>

        </classes>

    </test>

    <!-- WebKit -->
    <test name="WebKit">

        <parameter name="browser" value="webkit"/>

        <classes>

            <class name="tests.LoginTest"/>

            <class name="tests.LogoutTest"/>

        </classes>

    </test>

</suite>